# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# -----------------------------------------------------------------------------
# Secrets & environment — do NOT commit (prevents leaks to GitHub).
# Use only committed templates: .env.example, .env.local.example, backend/.env*.example
# -----------------------------------------------------------------------------
.env
.env.local
.env.*
backend/.env
backend/.env.local
backend/.env.*
.envrc
.env.vercel
.env*.backup
.env*.bak

# Allow safe templates (must come after ignore rules above)
!.env.example
!.env.local.example
!.env.*.example
!backend/.env.example
!backend/.env.local.example

# Copia anidada con su propio .git (no es parte del monorepo principal)
aria-app/

# vercel
.vercel

# python (backend)
backend/venv/
**/__pycache__/
*.py[cod]
.pytest_cache/

# typescript
*.tsbuildinfo
next-env.d.ts
