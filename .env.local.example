# Copiar a .env.local en la raíz del proyecto (Next.js lo carga automáticamente).

# Desarrollo local (FastAPI en tu máquina)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Vercel: no uses .env.local en producción; define la variable en el proyecto:
#   vercel env add NEXT_PUBLIC_API_URL
#   o Dashboard → Settings → Environment Variables
# Ejemplo: https://tu-api.ejemplo.com  (https, sin barra al final)
# Ver guía: VERCEL.md
