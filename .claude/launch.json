{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Frontend (Next.js)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "autoPort": false
    },
    {
      "name": "Backend (FastAPI)",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "cd backend && uvicorn app.main:app --reload --host 0.0.0.0 --port 8000"],
      "port": 8000,
      "autoPort": false
    }
  ]
}
