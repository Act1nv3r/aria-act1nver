# Plantilla: copiar a .env.local (preferido) o .env en esta carpeta.
# Con ambos archivos, .env.local sobrescribe .env.
#
# Si PostgreSQL local usa 5432, usa 5433 en docker-compose. Entonces:
DATABASE_URL=postgresql+asyncpg://aria:aria_secret@localhost:5433/aria
REDIS_URL=redis://localhost:6380/0
# En producción, añade el origen del front (Vercel), p. ej. https://aria-actinver.vercel.app
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Voz backend (Sprint 20): mover API keys del frontend al servidor
DEEPGRAM_API_KEY=
ANTHROPIC_API_KEY=
